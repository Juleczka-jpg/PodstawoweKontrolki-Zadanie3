<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp8.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="15">

            <Label Text="Wybierz wielkość:" FontAttributes="Bold"/>
            <RadioButton Content="Mała (25 cm) – 20 zł" GroupName="Size" Value="20" CheckedChanged="OnOptionChanged"/>
            <RadioButton Content="Średnia (32 cm) – 28 zł" GroupName="Size" Value="28" CheckedChanged="OnOptionChanged"/>
            <RadioButton Content="Duża (45 cm) – 38 zł" GroupName="Size" Value="38" CheckedChanged="OnOptionChanged"/>

            <Label Text="Wybierz rodzaj ciasta:" FontAttributes="Bold"/>
            <RadioButton Content="Cienkie" GroupName="Dough" Value="0" CheckedChanged="OnOptionChanged"/>
            <RadioButton Content="Grube" GroupName="Dough" Value="0" CheckedChanged="OnOptionChanged"/>
            <RadioButton Content="Z serem w brzegu (+5 zł)" GroupName="Dough" Value="5" CheckedChanged="OnOptionChanged"/>

            <Label Text="Wybierz ilość:" FontAttributes="Bold"/>
            <Stepper x:Name="QuantityStepper" Minimum="1" Maximum="10" Increment="1" ValueChanged="OnOptionChanged"/>
            <Label x:Name="QuantityLabel" Text="1 szt." />

            <Label Text="Wybierz godzinę dostawy:" FontAttributes="Bold"/>
            <TimePicker x:Name="DeliveryTime" Format="HH:mm" />

            <Label Text="Cena całkowita:" FontAttributes="Bold" />
            <Label x:Name="TotalPriceLabel"/>
            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
